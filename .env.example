# Django
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres
POSTGRES_DB=labexporthub
POSTGRES_USER=labexporthub
POSTGRES_PASSWORD=labexporthub
DATABASE_URL=postgresql://labexporthub:labexporthub@db:5432/labexporthub

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# S3 (MinIO)
S3_ENDPOINT_URL=http://minio:9000
S3_PRESIGN_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_EXPORTS=exports
S3_PRESIGNED_EXPIRES=300

# MinIO console
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
